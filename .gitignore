*.webm

# Live runtime data — never commit generated artifacts, uploaded sources, the
# founder's reference library, dropped transcripts/CSVs, or the health snapshot.
# Sidecar cards under artifacts/ carry prompts and local machine paths; keeping
# the whole tree out of git closes that leak path. These dirs are created at
# runtime on each machine, not shipped in the kit.
artifacts/
references/
inbox/
status.json

# Identity profile reference photos (personal images, never committed).
# The profile.json schema ships in the kit; actual photos stay on-machine.
profiles/*/references/*.jpg
profiles/*/references/*.jpeg
profiles/*/references/*.png

# Staged identity-training data is local/private too.  Keep the instructions
# in profiles/*/lora_dataset/, but never stage the copied source images,
# captions, or locally generated manifests.
profiles/*/lora_dataset/*/*/

# A dedicated trainer lives beside ComfyUI on BYRD-GAMING, but is an installed
# local runtime rather than source controlled application code.
Generators/sd-scripts/

# Backups
*.bak
*.bak-*
*_backup/
Backups/
*.zip
*.7z

# ByrdCoder generated machine config (real LM Studio URL substituted from
# byrdhouse.config.json at start time) — the example ships in configs/byrdcoder/,
# the live copy never enters git.
LLM/byrdcoder/

# ComfyUI MCP Workflow Lab scratch graphs are disposable/local; only the
# lab rules README is tracked. Candidates (workflows/candidates/) ARE tracked
# — they are reviewed artifacts headed for production.
workflows/experiments/comfyui-mcp-lab/*
!workflows/experiments/comfyui-mcp-lab/README.md

# Local verification and temporary reports
_verification/

# Windows and editors
Thumbs.db
Desktop.ini
.vscode/
.idea/
