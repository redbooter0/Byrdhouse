# comfyui-mcp Workflow Lab environment (Role B, docs/BYRDCODER_COMFY_MCP.md).
# Copy next to the machine config (LLM\byrdcoder\comfyui-mcp-lab.env) and fill
# CHANGE_ME values there — the real file never enters git.
#
# PINNED VERSION (do not use latest):
#   npm package : comfyui-mcp@0.34.0
#   git tag     : v0.34.0
#   commit      : 6a7ceeb9b578a149b0da65b43e0def708f0b3078
#   license     : MIT
# v0.35.0+ exists upstream; upgrading the pin is a founder decision recorded
# in DECISIONS.md after re-review.
#
# HARD RULES: this server only ever points at the ISOLATED Workflow Lab
# ComfyUI instance — NEVER production (byrd-gaming:8188). No tunnels
# (--tunnel is forbidden), no CivitAI/HF tokens in this file (downloads are
# denied in the lab), no autoinstall, no autoupdate.

# The isolated Workflow Lab ComfyUI (separate install + port, e.g. loopback
# :8189 on GAMING — see the lab setup section of docs/BYRDCODER_COMFY_MCP.md):
COMFYUI_URL=CHANGE_ME_lab_instance_e.g._http://127.0.0.1:8189

# Kill every self-modification path:
COMFYUI_MCP_PANEL_AUTOINSTALL=0
COMFYUI_MCP_AUTOUPDATE=0

# Compact tool mode: 3 meta-tools instead of the full 108-tool surface —
# smaller attack surface, fits small local-model contexts:
COMFYUI_MCP_TOOL_MODE=compact

# Deliberately ABSENT (never add here): CIVITAI_API_TOKEN, HUGGINGFACE_TOKEN,
# COMFYUI_API_KEY (no Comfy Cloud), COMFYUI_MCP_FORCE_REMOTE.
LOG_LEVEL=info
