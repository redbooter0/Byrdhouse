{
  "_comment": "AUTO face zone — the daily driver: upload ANY character picture (Gojo, Vegeta, Luffy, Link...), the detector finds the face, masks it, redraws it as YOU (identity LoRA + prompt) in the target's own art style, and composites it back. One node does detect->mask->inpaint->composite (Impact Pack FaceDetailer + Ultralytics face detector — see docs/MODELS.md). byrdimage.facezone_auto() fills checkpoint/seed/denoise/prompt and splices the LoRA. If a very stylized face isn't detected, fall back to the zone route (faceswap_inpaint_api.json) with a hand mask.",
  "target": {
    "class_type": "LoadImage",
    "inputs": { "image": "" }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "animagine-xl-4.0.safetensors" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["4", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["4", 1] }
  },
  "det": {
    "class_type": "UltralyticsDetectorProvider",
    "inputs": { "model_name": "bbox/face_yolov8m.pt" }
  },
  "fd": {
    "class_type": "FaceDetailer",
    "inputs": {
      "image": ["target", 0],
      "model": ["4", 0],
      "clip": ["4", 1],
      "vae": ["4", 2],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "bbox_detector": ["det", 0],
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": 0,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.7,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1,
      "inpaint_model": false,
      "noise_mask_feather": 20
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "byrdhouse_facezone_auto", "images": ["fd", 0] }
  }
}
