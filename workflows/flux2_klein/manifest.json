{
  "package": "ByrdHouse Flux2 Klein — Real to Gaming Character",
  "version": "2.0.0",
  "target": {
    "host": "BYRD-GAMING",
    "gpu": "RTX 3070",
    "vram_gb": 8
  },
  "workflow_files": [
    "safe_first_run.json",
    "real_to_gaming_api_v1.json",
    "production_all_in_one.json",
    "master_operator.json"
  ],
  "recommended_first_file": "safe_first_run.json",
  "api_workflow": "real_to_gaming_api_v1.json",
  "production_file": "production_all_in_one.json",
  "recipe_file": "../../recipes/real_to_gaming.v1.json",
  "models_required": [
    {
      "file": "flux-2-klein-9b-fp8.safetensors",
      "suggested_folder": "models/diffusion_models or models/unet",
      "role": "generation model"
    },
    {
      "file": "qwen_3_8b_fp8mixed.safetensors",
      "suggested_folder": "models/text_encoders",
      "role": "Flux2 text encoder"
    },
    {
      "file": "flux2-vae.safetensors",
      "suggested_folder": "models/vae",
      "role": "VAE"
    },
    {
      "file": "4x_foolhardy_Remacri.pth",
      "suggested_folder": "models/upscale_models",
      "role": "3070-friendly production upscaler"
    }
  ],
  "models_optional_seedvr2": [
    {
      "file": "seedvr2_ema_7b_sharp_fp8_e4m3fn_mixed_block35_fp16.safetensors",
      "role": "heavy SeedVR2 DiT"
    },
    {
      "file": "ema_vae_fp16.safetensors",
      "role": "SeedVR2 VAE"
    }
  ],
  "custom_nodes_required": [
    {
      "node_pack": "ComfyUI-Use-Everywhere",
      "nodes": ["GetNode", "SetNode"]
    },
    {
      "node_pack": "rgthree-comfy",
      "nodes": ["Seed (rgthree)", "Image Comparer (rgthree)", "Fast Groups Bypasser (rgthree)"]
    },
    {
      "node_pack": "comfyui_xiser_nodes",
      "nodes": ["XIS_INT_Slider", "XIS_Float_Slider"]
    }
  ],
  "custom_nodes_optional": [
    {
      "node_pack": "seedvr2_videoupscaler",
      "nodes": ["SeedVR2VideoUpscaler", "SeedVR2LoadDiTModel", "SeedVR2LoadVAEModel", "SeedVR2TorchCompileSettings"]
    }
  ],
  "outputs": {
    "gaming_prefix": "ByrdHouse/Flux2Klein/gaming/ByrdHouse_RealToGame",
    "raw_prefix": "ByrdHouse/Flux2Klein/raw/ByrdHouse_Flux2Klein_RAW",
    "upscaled_prefix": "ByrdHouse/Flux2Klein/upscaled/ByrdHouse_Flux2Klein_4X"
  },
  "styles": ["AAA", "HERO", "FANTASY", "SCIFI", "CEL_SHADED", "GRITTY", "SPLASH_ART"],
  "intensities": ["IDENTITY_LOCK", "BALANCED_GAMING", "FULL_CHARACTER_REDESIGN"],
  "api_controllable_nodes": {
    "92:74": "BYRDHOUSE TRANSFORMATION PROMPT — prompt text",
    "76": "REFERENCE 1 — subject photo filename",
    "81": "REFERENCE 2 — gaming style reference filename",
    "92:63": "GUIDANCE — CFG value (0.7-1.1)",
    "113": "SEED — integer (-1 for random)",
    "115": "STEPS — integer (default 28)",
    "92:80": "REF1 SCALE — megapixels for subject image (identity strength)",
    "92:85": "REF2 SCALE — megapixels for style reference (style strength)",
    "126": "SAVE — output filename prefix"
  },
  "api_integration": {
    "adapter": "api_adapter.py",
    "usage": "python api_adapter.py --workflow real_to_gaming_api_v1.json --output patched.json --reference-1 photo.png --reference-2 game_ref.png --style AAA --intensity BALANCED_GAMING"
  }
}
