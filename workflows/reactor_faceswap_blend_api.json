{
  "_comment": "ReActor swap + style blend: swap the face, then run a LOW-denoise img2img pass so the swapped face melts into stylized/anime art (Gojo, Vegeta, Luffy...) instead of looking pasted on. denoise = payload.style_blend (0.3-0.45 is the sweet spot). A character prompt + an anime checkpoint steer the blend; attach the trained identity LoRA to keep the face yours through the diffusion pass. Same node/model requirements as reactor_faceswap_api.json plus a checkpoint.",
  "target": {
    "class_type": "LoadImage",
    "inputs": { "image": "" }
  },
  "face": {
    "class_type": "LoadImage",
    "inputs": { "image": "" }
  },
  "swap": {
    "class_type": "ReActorFaceSwap",
    "inputs": {
      "enabled": true,
      "input_image": ["target", 0],
      "source_image": ["face", 0],
      "swap_model": "inswapper_128.onnx",
      "facedetection": "retinaface_resnet50",
      "face_restore_model": "GFPGANv1.4.pth",
      "face_restore_visibility": 1.0,
      "codeformer_weight": 0.5,
      "detect_gender_input": "no",
      "detect_gender_source": "no",
      "input_faces_index": "0",
      "source_faces_index": "0",
      "console_log_level": 1
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "animagine-xl-4.0.safetensors" }
  },
  "10": {
    "class_type": "VAEEncode",
    "inputs": { "pixels": ["swap", 0], "vae": ["4", 2] }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["4", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["4", 1] }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0, "steps": 30, "cfg": 7.0,
      "sampler_name": "dpmpp_2m", "scheduler": "karras",
      "denoise": 0.35,
      "model": ["4", 0], "positive": ["6", 0], "negative": ["7", 0],
      "latent_image": ["10", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "byrdhouse_swap_blend", "images": ["8", 0] }
  }
}
