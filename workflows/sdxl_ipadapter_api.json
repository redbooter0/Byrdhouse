{
  "_comment": "SDXL + IP-Adapter (reference-driven) graph in ComfyUI API format. THE 'make it look like THIS game' engine: a real screenshot/key-art reference steers the base checkpoint toward the game's actual look, colors and creatures — no per-game LoRA, no training. Needs the ComfyUI_IPAdapter_plus custom nodes + the IP-Adapter SDXL models (h94/IP-Adapter). byrdimage.generate(reference=...) fills checkpoint, prompt/negative (every CLIPTextEncode), seed, size, batch, filename_prefix, and uploads + wires the reference into LoadImage at submit time. Reference weight lives here (node 13) so it stays tunable without code.",
  "1": {
    "class_type": "LoadImage",
    "inputs": { "image": "" }
  },
  "12": {
    "class_type": "IPAdapterUnifiedLoader",
    "inputs": { "preset": "PLUS (high strength)", "model": ["4", 0] }
  },
  "13": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "weight": 0.8,
      "weight_type": "linear",
      "combine_embeds": "concat",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only",
      "model": ["12", 0],
      "ipadapter": ["12", 1],
      "image": ["1", 0]
    }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["13", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "juggernautXL_v9.safetensors" }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": 1152, "height": 768, "batch_size": 1 }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["4", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["4", 1] }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "byrdhouse_ref", "images": ["8", 0] }
  }
}
